# --- Databas ---
DATABASE_URL="postgresql://pokefinds:pokefinds@localhost:5432/pokefinds?schema=public"

# --- Auth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="byt-ut-mig-till-en-lang-slumpad-strang"

# --- Redis (valfri — appen fungerar utan, med in-memory fallback) ---
REDIS_URL="redis://localhost:6379"

# --- E-post ---
# console = loggar mail till terminalen (dev). smtp = riktig sändning.
EMAIL_MODE="console"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Foilio <noreply@foilio.se>"

# --- Pokémon TCG API (officiellt, gratis) ---
# Fungerar utan nyckel (lägre rate limit). Gratis nyckel: https://dev.pokemontcg.io
# Används av `npm run import:tcg` (riktiga sets/kort/bilder/marknadspriser).
POKEMONTCG_API_KEY=""

# --- Kortskanning / live-identifiering (OCR/vision) ---
# mock = inbyggd mock-adapter (demo). claude = riktig bildigenkänning via Claude
# vision (kräver ANTHROPIC_API_KEY). Live-identifieraren (/skanna) pollar videorutor.
OCR_PROVIDER="mock"
OCR_API_KEY=""
# Modell för kortidentifiering när OCR_PROVIDER=claude (snabb/billig räcker).
SCANNER_MODEL="claude-haiku-4-5"
# Månadsgräns för skanningar. Binder vision-kostnaden mot Pro-priset (no-match räknas ej).
SCANNER_FREE_MONTHLY_LIMIT="30"
SCANNER_PREMIUM_MONTHLY_LIMIT="100"
# Användarens N första skanningar körs med Sonnet (träffsäkert) för att haka nya användare.
SCANNER_INTRO_SONNET_SCANS="1"

# --- AI-kortgradering (PSA-liknande uppskattning) ---
# mock = deterministisk mock (ingen nyckel). claude = riktig Claude vision.
GRADING_PROVIDER="mock"
# Anthropic API-nyckel (krävs när GRADING_PROVIDER=claude).
ANTHROPIC_API_KEY=""
# Modell per plan. FREE = billigare/snabb, PREMIUM = mer noggrann (hög upplösning).
GRADING_MODEL_FREE="claude-haiku-4-5"
GRADING_MODEL_PREMIUM="claude-sonnet-4-6"
# Antal graderingar per månad. FREE = gratisgräns, PREMIUM = Pro-gräns mot Sonnet-kostnad.
GRADING_FREE_MONTHLY_LIMIT="3"
GRADING_PREMIUM_MONTHLY_LIMIT="15"

# --- Betalningar (förberett, avstängt i MVP) ---
STRIPE_ENABLED="false"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- Web push (förberett) ---
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# --- Cron / Auto-scrape ---
# CRON_SECRET: MÅSTE sättas för att /api/cron/scrape ska fungera (header x-cron-secret).
CRON_SECRET="byt-ut-mig-cron-hemlighet"
# SCRAPE_INTERVAL_MINUTES: Automatisk insamling körs i bakgrunden var N:e minut.
# Sätt 0 för att stänga av. Standard: 480 (8 timmar).
SCRAPE_INTERVAL_MINUTES="480"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Foilio"

# --- In-App Purchase (RevenueCat) — premium via Apple/Google i native-appen ---
# Publika SDK-nycklar (per plattform) från RevenueCat → Project → API keys.
NEXT_PUBLIC_RC_IOS_KEY=""
NEXT_PUBLIC_RC_ANDROID_KEY=""
# Delad hemlighet: sätt som Authorization-header på webhooken i RC-dashboarden.
REVENUECAT_WEBHOOK_AUTH=""
