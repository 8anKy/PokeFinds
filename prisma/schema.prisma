generator client {
  provider      = "prisma-client-js"
  // "native" = lokal Windows-motor (dev); "rhel-openssl-3.0.x" = Vercels Linux-
  // runtime (AL2023/OpenSSL 3); "debian-openssl-*" = Railways Debian-image (Railpack).
  // Flera targets så samma schema funkar på alla tre värdar.
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Role {
  USER
  MODERATOR
  ADMIN
  SUPERADMIN
}

enum ProductCategory {
  SINGLE_CARD
  BOOSTER_BOX
  BOOSTER_PACK
  ETB
  COLLECTION_BOX
  TIN
  BLISTER
  BUNDLE
  ACCESSORY
  GRADED_CARD
  OTHER
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  PREORDER
  LIMITED
  UNKNOWN
}

enum CardLanguage {
  SV
  EN
  JP
  DE
  FR
  OTHER
}

enum CardCondition {
  MINT
  NEAR_MINT
  EXCELLENT
  GOOD
  PLAYED
  POOR
  SEALED
}

enum AlertType {
  PRICE_DROP
  PRICE_TARGET
  RESTOCK
  NEW_LISTING
  TREND
  SYSTEM
}

enum AlertChannel {
  IN_APP
  EMAIL
  PUSH
}

enum AlertStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum SourceType {
  API
  FEED
  SCRAPER
  MANUAL
  MOCK
}

enum PostCategory {
  PULLS
  TRADES
  QUESTIONS
  MARKET
  NEWS
  COLLECTIONS
}

enum ReportStatus {
  OPEN
  REVIEWED
  ACTIONED
  DISMISSED
}

// Varför en användare anmäler ett butikserbjudande. En felaktig butikslänk är
// OSYNLIG för våra vakter (en länk som saknas syns aldrig) men HELT synlig för
// den enda person som klickat på den — användaren. Ge dem knappen.
enum OfferReportReason {
  WRONG_PRODUCT // länken går till en annan produkt än den vi visar
  WRONG_PRICE // priset stämmer inte med butikens sida
  DEAD_LINK // 404 / produkten finns inte längre
  OUT_OF_STOCK // vi visar "i lager" men butiken är slutsåld
}

enum PlanTier {
  FREE
  PREMIUM
}

// ---------- Auth & användare ----------

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  // Case-insensitivt unikt (lower(name)) via råmigration User_name_lower_key —
  // kan inte uttryckas här. Kör INTE `migrate dev` så att indexet tappas.
  name                 String
  passwordHash         String
  role                 Role      @default(USER)
  planTier             PlanTier  @default(FREE)
  avatarUrl            String?
  bio                  String?
  emailVerifiedAt      DateTime?
  verificationToken    String?   @unique
  resetToken           String?   @unique
  resetTokenExpiresAt  DateTime?
  onboardingCompleted  Boolean   @default(false)
  notificationSettings Json      @default("{\"email\":true,\"push\":false,\"allRestocks\":false}")
  lastPushError        String?    // debug: senaste APNs/push-registreringsfel (egen kolumn → ej clobbrad av settings-PATCH)
  preferences          Json      @default("{}")
  reputationScore      Int       @default(0)
  isPublicCollection   Boolean   @default(false)
  traderaUserId        String? // Traderas userId när kontot är kopplat (för "Sälj på Tradera")
  traderaToken         String? // AuthToken från FetchToken; behandlas som en hemlighet
  traderaTokenExpiresAt DateTime? // HardExpirationTime — koppla om kontot när denna passeras
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  watchlistItems  WatchlistItem[]
  alerts          Alert[]
  collectionItems CollectionItem[]
  posts           CommunityPost[]
  comments        Comment[]
  likes           Like[]
  scannerJobs     ScannerJob[]
  gradingJobs     GradingJob[]
  auditLogs       AuditLog[]
  notifications   Notification[]
  reports         Report[]
  offerReports    OfferReport[]
  savedPosts      SavedPost[]
  pushTokens      PushToken[]
  sales           Sale[]

  @@index([email])
}

// Såld annons (ögonblicksbild) — byggs när ett samlingsobjekts Tradera-annons säljs.
// Fristående från CollectionItem så sålda poster aldrig läcker in i aktiv samling/värde.
model Sale {
  id               String   @id @default(cuid())
  userId           String
  name             String // namn vid försäljningstillfället (kortet kan vara borta ur samlingen)
  setName          String?
  imageUrl         String?
  condition        String
  language         String
  purchasePriceOre Int? // inköpspris (kostnadsbas), om känt
  salePriceOre     Int // Traderas transaktionsbelopp (brutto, före avgifter)
  soldAt           DateTime // transaktionens datum
  traderaItemId    String?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, soldAt])
}

// Enhetstoken för native push (iOS/APNs). En användare kan ha flera enheter.
model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("ios")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- Kortdata ----------

model CardSet {
  id          String    @id @default(cuid())
  name        String
  series      String
  releaseDate DateTime?
  logoUrl     String?
  symbolUrl   String?
  externalId  String?   @unique
  totalCards  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  cards    Card[]
  products Product[]

  @@index([name])
}

model Card {
  id            String       @id @default(cuid())
  name          String
  setId         String
  number        String
  rarity        String
  imageUrl      String?
  language      CardLanguage @default(EN)
  tcgExternalId String?      @unique
  // Cardmarket idProduct — identitet för promo-/specialset utan pokemontcg.io-tcgid
  // (t.ex. MEP Black Star Promos). Möjliggör idempotent import + daglig pris-refresh.
  cardmarketId  Int?         @unique
  supertype     String?
  subtype       String?
  artist        String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  set             CardSet          @relation(fields: [setId], references: [id])
  products        Product[]
  collectionItems CollectionItem[]

  // OBS: kortnummer är INTE unikt inom ett set (t.ex. Celebrations Classic
  // Collection har fyra kort med nummer 15). Identitet bygger på tcgExternalId
  // (globalt unikt API-id). Nummer+set är bara ett index för uppslag.
  @@index([setId, number, language])
  @@index([name])
  @@index([setId])
}

// ---------- Produkter & priser ----------

model Product {
  id              String          @id @default(cuid())
  title           String
  normalizedTitle String
  slug            String          @unique
  category        ProductCategory
  // Cardmarket har ofta flera produkter under samma kortnummer (vanlig common +
  // Poké/Master Ball reverse + promo). pokemontcg.io och RapidAPI mappar samma
  // tcgid till OLIKA CM-produkter. variantLabel != null = specialvariant som
  // prissätts via pokemontcg.io-trend (RapidAPI saknar den); null = bas-common
  // som prissätts via RapidAPI From. Se cardmarket-refresh.ts.
  variantLabel    String?
  // Tillverkarens streckkod, normaliserad till GTIN-14 (se src/lib/gtin.ts). Den EXAKTA
  // cross-store-nyckeln: samma nummer står på asken i varje butik i världen. Sätts av
  // auto-importen/backfillen från butikernas feeds (5 av 7 butiker publicerar den).
  //
  // MEDVETET INTE @unique: befintliga katalogdubbletter KROCKAR direkt vid backfill — och
  // krocken ÄR dubbletten vi vill hitta, inte ett fel att krascha på. Unikhet drivs i
  // stället av matchningen (GTIN-träff → länka i stället för att skapa) + konfliktrapporten.
  gtin            String?
  // Admin-kvittering av GRANSKADE streckkods-konflikter (länkfel-vyn). Lagrar de
  // konfliktdrivande koderna (sorterade, komma-separerade) som en admin markerat OK.
  // Vyn döljer konflikten så länge nyckeln matchar; dyker en NY avvikande kod upp
  // ändras nyckeln → konflikten återuppstår automatiskt. Se src/services/gtin-conflicts.ts.
  gtinConflictAckKey String?
  cardId          String?
  setId           String?
  imageUrl        String?
  description     String?
  releaseDate     DateTime?
  language        CardLanguage    @default(EN)
  viewCount       Int             @default(0)
  clickCount      Int             @default(0)
  // Denormaliserat lägsta prissatta offer-pris (öre) — null = inget pris (gömd ur
  // katalogen tills den får ett pris). Möjliggör DB-nivå prissortering +
  // paginering (infinite scroll) utan att läsa in alla offers. Räknas om av
  // recomputeProductPriceCache() efter scrape/refresh.
  lowestPriceOre  Int?
  // Senast namn-sökt på Tradera (roterande full-katalog-svep). null = aldrig sökt
  // → prioriteras först. Se src/jobs/tradera-sweep.ts (Fas 0).
  traderaCheckedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  card              Card?              @relation(fields: [cardId], references: [id])
  set               CardSet?           @relation(fields: [setId], references: [id])
  offers            Offer[]
  priceObservations PriceObservation[]
  restockEvents     RestockEvent[]
  watchlistItems    WatchlistItem[]
  alerts            Alert[]
  collectionItems   CollectionItem[]
  priceSnapshots    PriceSnapshot[]
  traderaListings   TraderaListing[]

  @@index([normalizedTitle])
  @@index([category])
  @@index([setId])
  @@index([lowestPriceOre])
}

model Retailer {
  id               String   @id @default(cuid())
  name             String   @unique
  websiteUrl       String
  logoUrl          String?
  country          String   @default("SE")
  isActive         Boolean  @default(true)
  sourceType       SourceType @default(MANUAL)
  affiliateEnabled Boolean  @default(false)
  affiliateParams  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  offers        Offer[]
  restockEvents RestockEvent[]
  storeListings StoreListing[]
}

// Feed-först-huvudbok: RÅ butiksannonser per URL, oberoende av katalogen. Låter
// restock-skanningen larma om HELT NYA produkter (URL:er vi aldrig sett) och om
// restocks av produkter som inte finns i katalogen — det som matchnings-baserade
// offers missar. Bara URL:er UTAN en matchande Offer hamnar här (matchade sköts av
// den beprövade offer-diffen). Se runRestockScan.
model StoreListing {
  id          String      @id @default(cuid())
  retailerId  String
  url         String
  title       String
  price       Int? // öre — från feeden (kan saknas)
  imageUrl    String?
  stockStatus StockStatus @default(UNKNOWN)
  // Streckkod för den råa annonsen (GTIN-14). Cachas här så auto-importen slipper
  // hämta om den för en URL vi redan slagit upp.
  gtin        String?
  firstSeenAt DateTime    @default(now())
  lastSeenAt  DateTime    @default(now())

  retailer Retailer @relation(fields: [retailerId], references: [id])
  alerts   Alert[]

  @@unique([retailerId, url])
  @@index([retailerId])
}

model Offer {
  id            String        @id @default(cuid())
  productId     String
  retailerId    String
  url           String
  price         Int? // öre — null = länk-offer utan känt pris (t.ex. auktioner)
  currency      String        @default("SEK")
  stockStatus   StockStatus   @default(UNKNOWN)
  // Streckkoden butiken publicerar för DENNA sida (GTIN-14, se src/lib/gtin.ts).
  // Två offers på samma produkt med OLIKA gtin = bevisad felaktig butikslänk
  // (ren SQL-detektor, noll LLM). null = butiken publicerar ingen kod (normalt).
  gtin          String?
  shippingPrice Int?
  condition     CardCondition @default(SEALED)
  language      CardLanguage  @default(EN)
  lastSeenAt    DateTime      @default(now())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  retailer  Retailer   @relation(fields: [retailerId], references: [id])
  dealCheck DealCheck?
  reports   OfferReport[]

  @@unique([productId, retailerId, condition, language])
  @@index([productId])
  @@index([stockStatus])
  @@index([gtin])
}

// Global Tradera-matchningsdom: har en LLM bekräftat att Tradera-annonsen (itemId)
// VERKLIGEN är samma produkt OCH komplett/oöppnad/oskadad/aktiv? Överlever offer-
// nollställning → sweepen slår upp ok=false och återskapar ALDRIG en känd felmatch.
// Bara sealed (singlar matchas på setnummer). Keyad på annons+produkt (stabilt).
/// Levande Tradera-annonser per produkt — produktsidans "Fler annonser på
/// Tradera"-skena (#19). Fylls av tradera-sweep Fas 0 (samma sökning som redan
/// görs för billigast-offerten; vi slänger bara inte längre resten). Ersätts som
/// HELT SET varje gång produkten namn-söks; rader äldre än några dagar visas
/// aldrig (annonsen kan ha sålts) och purgas av svepet. Billigaste annonsen är
/// FORTFARANDE Offer:en — den här tabellen är enbart skenan.
model TraderaListing {
  id         String   @id @default(cuid())
  productId  String
  itemId     String
  title      String
  price      Int // öre (Buy It Now)
  url        String
  imageUrl   String?
  lastSeenAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, itemId])
  @@index([productId, lastSeenAt])
  @@index([lastSeenAt])
}

model TraderaMatch {
  itemId    String
  productId String
  ok        Boolean // sameProduct && sealedComplete && !ended && remaining>0
  reason    String?
  checkedAt DateTime @default(now())

  @@id([itemId, productId])
  @@index([productId])
}

/// Cache för dedupe-stubs LLM-domar ("är dessa två titlar samma produkt?").
///
/// Utan den betalade veckojobbet för SAMMA dom om och om igen: en stub som döms
/// "inte dubblett" ligger kvar i 14-dagarsfönstret och döms på nytt NÄSTA måndag,
/// och nästa — samma två titlar, samma svar, ny kostnad. ~505 anrop/vecka blev
/// merparten omdömen vi redan hade. (Positiva domar cachas ocksÅ men blir sällan
/// lästa: en träff mergas direkt och stubben försvinner.)
///
/// Nyckel = produktparet SORTERAT (aId < bId) så (A,B) och (B,A) är samma rad.
/// Titlarna sparas med domen: ändras en titel (eller cleanListingTitle:s
/// utdata) är domen inte längre giltig → vi dömer om i stället för att lita på
/// ett svar som gällde en annan text. Ingen FK (som TraderaMatch) → städas
/// manuellt i mergeStubInto.
model DedupeVerdict {
  productAId String
  productBId String
  /// Titlarna som FAKTISKT dömdes (efter cleanListingTitle) — cache-invalidering.
  titleA     String
  titleB     String
  same       Boolean
  reason     String?
  checkedAt  DateTime @default(now())

  @@id([productAId, productBId])
  @@index([productBId])
}

// Fynd-verifiering (Pro): LLM-koll att en Tradera-annons VERKLIGEN är samma sealed
// produkt och är komplett/oöppnad/oskadad. Körs bara på fynd-kandidater (liten mängd)
// så vi har råd med ett dyrt anrop per annons. 1:1 mot Offer.
model DealCheck {
  offerId      String    @id
  offer        Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  ok           Boolean // sameProduct && sealedComplete && !ended
  checkedPrice Int // öre priset verifierades vid — omverifiera om Offer.price ändras
  listingTitle String? // Tradera ShortDescription (visas på kortet för transparens)
  reason       String? // kort motivering (t.ex. "tom ask", "fel produkt")
  endsAt       DateTime? // Tradera EndDate → dölj när annonsen löpt ut
  checkedAt    DateTime  @default(now())
}

model PriceObservation {
  id         String        @id @default(cuid())
  productId  String
  sourceId   String?
  price      Int // öre
  currency   String        @default("SEK")
  condition  CardCondition @default(SEALED)
  observedAt DateTime      @default(now())
  rawData    Json?

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  source  ScrapeSource? @relation(fields: [sourceId], references: [id])

  @@index([productId, observedAt])
}

// Daglig aggregerad prisdata för snabba grafer
model PriceSnapshot {
  id        String   @id @default(cuid())
  productId String
  date      DateTime @db.Date
  minPrice  Int
  maxPrice  Int
  avgPrice  Int
  volume    Int      @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([productId, date])
}

model RestockEvent {
  id         String      @id @default(cuid())
  productId  String
  retailerId String
  oldStatus  StockStatus
  newStatus  StockStatus
  price      Int?
  detectedAt DateTime    @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  retailer Retailer @relation(fields: [retailerId], references: [id])

  @@index([productId, detectedAt])
  @@index([detectedAt])
}

// ---------- Bevakning & alerts ----------

model WatchlistItem {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  targetPrice  Int?
  maxPrice     Int?
  restockAlert Boolean  @default(true)
  priceAlert   Boolean  @default(true)
  channels     Json     @default("[\"IN_APP\",\"EMAIL\"]")
  isPaused     Boolean  @default(false)
  createdAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Alert {
  id          String       @id @default(cuid())
  userId         String
  productId      String?
  retailerId     String?      // butiken som utlöste larmet (restock) → mejl länkar direkt dit
  storeListingId String?      // feed-först-larm (ny produkt/restock utanför katalogen) → mejl bygger på annonsen
  type           AlertType
  message        String
  channel        AlertChannel @default(IN_APP)
  status         AlertStatus  @default(PENDING)
  retryCount     Int          @default(0)
  triggeredAt    DateTime     @default(now())
  sentAt         DateTime?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product      Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  storeListing StoreListing? @relation(fields: [storeListingId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([status])
}

/// DÖD SEDAN dfa4247 — in-app-notiser är BORTTAGNA (ersatta av e-post + native push
/// via APNs). Ingenting skriver eller läser den här tabellen längre; de 4 kvarvarande
/// raderna (senast 2026-06-26) är rester från före den commiten. Tabellen är kvar bara
/// för att slippa en migration på prod. Bygg INTE nytt mot den — och tro inte att en
/// tom Notification-tabell betyder att larmen är trasiga (det spårledet kostade en
/// utredning 2026-07-12). Larmens sanning finns i Alert + dispatchPendingAlerts.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ---------- Samling ----------

model CollectionItem {
  id             String         @id @default(cuid())
  userId         String
  cardId         String?
  productId      String?
  quantity       Int            @default(1)
  condition      CardCondition  @default(NEAR_MINT)
  language       CardLanguage   @default(EN)
  purchasePrice  Int? // öre
  purchaseDate   DateTime?
  estimatedValue Int? // öre
  gradingCompany String?
  grade          String?
  notes          String?
  imageUrl       String?
  // Traderas objektnr när objektet lagts ut till försäljning (för auto-borttagning vid sålt).
  traderaItemId  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card    Card?    @relation(fields: [cardId], references: [id])
  product Product? @relation(fields: [productId], references: [id])

  @@index([userId])
}

// ---------- Community ----------

model CommunityPost {
  id        String       @id @default(cuid())
  userId    String
  title     String
  content   String
  imageUrl  String?
  category  PostCategory
  isHidden  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments   Comment[]
  likes      Like[]
  reports    Report[]
  savedPosts SavedPost[]

  @@index([category, createdAt])
  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  content   String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Like {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model SavedPost {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Report {
  id         String       @id @default(cuid())
  postId     String
  reporterId String
  reason     String
  status     ReportStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  post     CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User          @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
}

// Användaranmälan av ett felaktigt butikserbjudande — den enda rättningsloop som
// skalar bortom vakter, fixturer och revisionsskript. Vår katalogrevision hittade 6%
// felaktiga länkar, men bara för att någon KÖRDE ett svep; en felmatch upptäcks annars
// först när en användare klickar och landar på fel vara.
//
// Rättas ALLTID mot RÅDATA (radera/omdirigera Offer via ID) — aldrig genom att lappa
// det visade aggregatet. Det är också vad den enda verifierade konkurrentpraxisen gör.
model OfferReport {
  id         String            @id @default(cuid())
  offerId    String
  // null = anonym anmälan (utloggad besökare). Vi vill hellre ha signalen än ett konto.
  reporterId String?
  reason     OfferReportReason
  note       String?
  status     ReportStatus      @default(OPEN)
  createdAt  DateTime          @default(now())
  resolvedAt DateTime?

  offer    Offer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  reporter User? @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([offerId])
}

// ---------- Datainsamling ----------

model ScrapeSource {
  id        String     @id @default(cuid())
  name      String     @unique
  baseUrl   String
  type      SourceType @default(MOCK)
  isActive  Boolean    @default(true)
  config    Json       @default("{}")
  lastRunAt DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  jobs              ScrapeJob[]
  priceObservations PriceObservation[]
}

model ScrapeJob {
  id           String    @id @default(cuid())
  sourceId     String
  status       JobStatus @default(QUEUED)
  startedAt    DateTime?
  finishedAt   DateTime?
  itemsFound   Int       @default(0)
  itemsUpdated Int       @default(0)
  errorMessage String?
  logs         Json      @default("[]")
  createdAt    DateTime  @default(now())

  source ScrapeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, createdAt])
  @@index([status])
}

// ---------- Kortskanning ----------

model ScannerJob {
  id         String    @id @default(cuid())
  userId     String
  imageUrl   String
  status     JobStatus @default(QUEUED)
  result     Json?
  confidence Float?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// AI-baserad kortgradering (PSA-liknande uppskattning från fram-/baksidesbild).
model GradingJob {
  id            String    @id @default(cuid())
  userId        String
  frontImageUrl String
  backImageUrl  String
  status        JobStatus @default(QUEUED)
  // result innehåller delpoäng (centering/corners/edges/surface), motivering,
  // använd modell + ev. matchat kort. overallGrade = sammanvägd 1–10.
  result        Json?
  overallGrade  Float?
  confidence    Float?
  modelUsed     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
}

// ---------- Audit & analytics ----------

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, createdAt])
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String // product_view, retailer_click, watchlist_add, search, alert_sent
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([eventType, createdAt])
}
