{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Bash(cat .env:*)",
      "Bash(cat ./.env:*)",
      "Bash(type .env:*)",
      "Bash(grep:* .env)",
      "Bash(grep:* ./.env)",
      "Bash(rg:* .env)",
      "Bash(head:* .env)",
      "Bash(tail:* .env)",
      "Bash(printenv:*)",
      "Bash(env)"
    ]
  }
}
